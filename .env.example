# Database — Neon Postgres (or Vercel Postgres). Attaching a Vercel Postgres
# database sets POSTGRES_URL automatically; a standalone Neon database gives you
# a DATABASE_URL. Either one works.
DATABASE_URL=

# Twilio SMS (optional — the site works without it, contact form just won't text)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Your cell — gets a text every time someone submits the contact form
ADMIN_PHONE=+1XXXXXXXXXX

# Public site URL (used for metadata / links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
